#!/usr/bin/env bash
# Bootstrap a fresh macOS box: brew + Brewfile, rustup, go bins, nushell as login shell.
# Usage:  bash bootstrap                                   # clones default DOTFILES_REMOTE
#         DOTFILES_REMOTE=git@github.com:fork/dotfiles.git bash bootstrap   # override

set -euo pipefail

# Default origin — override via env var when forking
: "${DOTFILES_REMOTE:=https://github.com/tyarnell/dotfiles.git}"
BREWFILE="$HOME/.config/dotfiles/Brewfile"

log() { printf '\n\033[1;34m>> %s\033[0m\n' "$*"; }
die() { printf '\n\033[1;31m!! %s\033[0m\n' "$*" >&2; exit 1; }

# ── Xcode CLT ────────────────────────────────────────────────────────────────
if ! xcode-select -p >/dev/null 2>&1; then
  log "Installing Xcode Command Line Tools (accept the dialog, then re-run)"
  xcode-select --install
  exit 0
fi

# ── Homebrew ─────────────────────────────────────────────────────────────────
if ! command -v brew >/dev/null 2>&1; then
  log "Installing Homebrew"
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
eval "$(/opt/homebrew/bin/brew shellenv)"

# ── Dotfiles (bare repo) ─────────────────────────────────────────────────────
if [[ ! -d "$HOME/.dotfiles" ]]; then
  log "Cloning dotfiles from $DOTFILES_REMOTE"
  git clone --bare "$DOTFILES_REMOTE" "$HOME/.dotfiles"
fi

# Ensure tracked files are checked out into $HOME. `reset --hard HEAD` forces
# work tree + index to match HEAD — self-heals from any partial-checkout state
# (empty index, conflicting pre-existing files, half-applied checkout).
# Only runs when Brewfile is absent so it never clobbers post-bootstrap edits.
if [[ ! -f "$BREWFILE" ]]; then
  log "Checking out tracked files into \$HOME"
  git --git-dir="$HOME/.dotfiles" --work-tree="$HOME" reset --hard HEAD
  git --git-dir="$HOME/.dotfiles" --work-tree="$HOME" config status.showUntrackedFiles no
fi

# ── macOS: symlink Library/Application Support/nushell → .config/nushell ─────
# Nushell on macOS defaults to ~/Library/Application Support/nushell. Point it
# at the portable ~/.config/nushell location so the same files work on Linux.
if [[ "$(uname -s)" == "Darwin" && -d "$HOME/.config/nushell" ]]; then
  NU_LIB="$HOME/Library/Application Support/nushell"
  mkdir -p "$NU_LIB"
  for f in env.nu config.nu; do
    if [[ -e "$HOME/.config/nushell/$f" && ! -L "$NU_LIB/$f" ]]; then
      rm -f "$NU_LIB/$f"
      ln -s "$HOME/.config/nushell/$f" "$NU_LIB/$f"
    fi
  done
fi

# ── Brewfile ─────────────────────────────────────────────────────────────────
[[ -f "$BREWFILE" ]] || die "Brewfile not found at $BREWFILE — did the dotfiles checkout run?"
log "Installing Brew packages"
brew bundle install --file="$BREWFILE"

# ── Rust ─────────────────────────────────────────────────────────────────────
if ! command -v rustup >/dev/null 2>&1; then
  log "Installing rustup"
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --no-modify-path
fi
export PATH="$HOME/.cargo/bin:$PATH"

log "Adding Rust components"
rustup component add rust-analyzer rustfmt clippy

log "Installing cargo bins"
cargo install simple-completion-language-server

# ── Go ───────────────────────────────────────────────────────────────────────
export GOPATH="$HOME/go"
export PATH="$GOPATH/bin:$PATH"

log "Installing Go bins"
go install golang.org/x/tools/gopls@latest
go install github.com/go-delve/delve/cmd/dlv@latest
go install golang.org/x/tools/cmd/goimports@latest
go install github.com/cweill/gotests/gotests@latest
go install honnef.co/go/tools/cmd/staticcheck@latest

# ── Login shell ──────────────────────────────────────────────────────────────
NU="$(command -v nu)"
if ! grep -qx "$NU" /etc/shells; then
  log "Adding nu to /etc/shells (requires sudo)"
  echo "$NU" | sudo tee -a /etc/shells >/dev/null
fi
if [[ "${SHELL:-}" != "$NU" ]]; then
  log "To set nushell as login shell, run:  chsh -s $NU"
fi

log "Done. Open a new terminal."
